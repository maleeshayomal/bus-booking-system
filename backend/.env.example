# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lankatransit

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# OTP (mock provider by default; swap in a real SMS gateway such as Twilio / Notify.lk)
OTP_EXPIRY_MINUTES=5
SMS_PROVIDER_API_KEY=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
